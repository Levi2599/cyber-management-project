      {
        "para_index": 5,
        "text": "\u05de\u05e0\u05d9\u05d5\u05ea \u05d8\u05db\u05e0\u05d5\u05dc\u05d5\u05d2\u05d9\u05d4 \u05d5\u05e6\u05de\u05d9\u05d7\u05d4 (AAPL, MSFT, AMZN, NVDA): \u05e0\u05db\u05e1\u05d9\u05dd \u05d1\u05e2\u05dc\u05d9 \u05e8\u05de\u05ea \u05ea\u05e0\u05d5\u05d3\u05ea\u05d9\u05d5\u05ea \u05d2\u05d1\u05d5\u05d4\u05d4 \u05d5\u05e4\u05d5\u05d8\u05e0\u05e6\u05d9\u05d0\u05dc \u05ea\u05e9\u05d5\u05d0\u05d4 \u05e2\u05d5\u05d3\u05e3.",
        "style": "List Paragraph"
      },
      {
        "para_index": 6,
        "text": "\u05e1\u05e7\u05d8\u05d5\u05e8 \u05d4\u05d0\u05e0\u05e8\u05d2\u05d9\u05d4 (XLE): \u05e1\u05e7\u05d8\u05d5\u05e8 \u05de\u05e1\u05d5\u05e8\u05ea\u05d9 \u05d1\u05e2\u05dc \u05d4\u05ea\u05e0\u05d4\u05d2\u05d5\u05ea \u05de\u05d7\u05d6\u05d5\u05e8\u05d9\u05ea \u05d4\u05d9\u05d9\u05d7\u05d5\u05d3\u05d9\u05ea \u05dc\u05e9\u05d5\u05e7 \u05d4\u05e1\u05d7\u05d5\u05e8\u05d5\u05ea.",
        "style": "List Paragraph"
      },
      {
        "para_index": 7,
        "text": "\u05de\u05d3\u05d3 \u05d4\u05e9\u05d5\u05e7 \u05d4\u05e8\u05d7\u05d1 (SPY): \u05de\u05e9\u05ea\u05e0\u05d4 \u05d4\u05de\u05d8\u05e8\u05d4 \u05e9\u05dc \u05d4\u05de\u05d7\u05e7\u05e8, \u05d4\u05de\u05d9\u05d9\u05e6\u05d2 \u05d0\u05ea \u05d4\u05ea\u05e0\u05d4\u05d2\u05d5\u05ea \u05d4\u05e9\u05d5\u05e7 \u05d4\u05d0\u05de\u05e8\u05d9\u05e7\u05d0\u05d9 \u05d4\u05de\u05de\u05d5\u05e6\u05e2.",
