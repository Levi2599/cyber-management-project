# העתיקו לקובץ בשם .env ומלאו את הערכים. הקובץ .env נמצא ב-.gitignore ואינו נדחף.
# אין להטמיע מפתחות בקוד — המאגר הזה ציבורי.

# מפתח ה-API של n8n. נוצר ב-n8n תחת Settings -> API.
N8N_API_KEY=

# כתובת הבסיס של שרת ה-n8n.
N8N_BASE_URL=http://localhost:5678

# מזהה הוורקפלו שעליו פועלים סקריפטי העזר.
N8N_WORKFLOW_ID=dualCodeAuditor01
